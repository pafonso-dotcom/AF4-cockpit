    "catalogo:dev": "pnpm --filter @repo/catalogo dev",
    "catalogo:build": "pnpm --filter @repo/catalogo build",
    "catalogo:start": "pnpm --filter @repo/catalogo start"
  },
  "devDependencies": {
    "turbo": "^2.9.8"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@10.33.2"
}
