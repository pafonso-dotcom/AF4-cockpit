{
  "name": "afinancas-pessoal",
  "version": "2.0.0",
  "private": true,
  "description": "Afinanças · pessoal — app pessoal (deploy: worker afinancas-pessoal). O comercial é o pacote numvi-financas, à parte.",
  "scripts": {
    "build": "turbo run build",
    "start": "pnpm --filter @repo/cars-web start",
