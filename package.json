{
  "name": "af4-financecars",
  "version": "2.0.0",
  "private": true,
  "description": "AF4 Cockpit · Vite SPA wrapper para deploy via turbo",
  "scripts": {
    "build": "turbo run build",
    "start": "pnpm --filter @repo/cars-web start",
    "dev": "pnpm --filter @repo/cars-web dev",
    "catalogo:dev": "pnpm --filter @repo/catalogo dev",
    "catalogo:build": "pnpm --filter @repo/catalogo build",
    "catalogo:start": "pnpm --filter @repo/catalogo start"
  },
  "devDependencies": {
    "turbo": "^2.9.8"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@10.33.2"
}
