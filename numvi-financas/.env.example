# ============================================================
# NUMVI · variáveis Vite (lidas em build time)
# ============================================================

# Variante do app (define branding + comportamento do Supabase):
#   pessoal    (default) → "Numvi·pessoal". Sem as VITE_SUPABASE_* abaixo,
#                          cai no Supabase pessoal do dono (dados existentes).
#   comercial             → "Numvi·finanças". EXIGE VITE_SUPABASE_URL/KEY
#                          próprios — sem eles o app fica "não configurado"
#                          (fail-closed), nunca usa o banco pessoal.
VITE_NUMVI_VARIANT=pessoal

# Projeto Supabase. Pegue em Supabase Dashboard → Settings → API.
# Obrigatório na variante "comercial"; opcional na "pessoal" (tem fallback).
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
