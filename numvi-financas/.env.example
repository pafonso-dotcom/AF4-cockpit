# ============================================================
# NUMVI · variáveis Vite (lidas em build time)
# ============================================================

# Variante do app (define branding + tabelas de dados):
#   pessoal    (default) → "Numvi·pessoal". Tabelas numvi_state / numvi_keys.
#   comercial             → "Numvi·finanças". Tabelas numvi_com_state / numvi_com_keys.
#
# Por agora pessoal e comercial PARTILHAM o mesmo projeto Supabase (limite de
# 2 projetos grátis por conta). A separação é por TABELA + RLS por usuário.
# Não precisas definir VITE_SUPABASE_* no comercial enquanto for o mesmo projeto.
VITE_NUMVI_VARIANT=pessoal

# Projeto Supabase (Settings → API). OPCIONAL: sem isto, usa o projeto pessoal
# padrão. Define só quando migrares o comercial para um projeto dedicado.
# VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
